# ---- Supabase (Project Settings > API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the browser. (Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Access control ----
# Comma-separated email domains allowed to sign in. Leave blank to allow anyone.
ALLOWED_EMAIL_DOMAINS=yourcompany.com

# ---- Slack notifications (Slack > Incoming Webhooks) ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ---- Keep-alive cron secret (any random string; used to protect the cron route) ----
CRON_SECRET=change-me-to-a-long-random-string
